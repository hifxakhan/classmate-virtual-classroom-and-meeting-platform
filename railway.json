{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd code/my-react-app/src/ClassMate-Backend && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd code/my-react-app/src/ClassMate-Backend && gunicorn --worker-class eventlet -w 1 --bind 0.0.0.0:$PORT --timeout 120 --access-logfile - --error-logfile - app:app"
  }
}
