{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd code/my-react-app/src/ClassMate-Backend && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "cd code/my-react-app/src/ClassMate-Backend && gunicorn --bind 0.0.0.0:$PORT app:app",
    "restartPolicyType": "ON_FAILURE"
  }
}