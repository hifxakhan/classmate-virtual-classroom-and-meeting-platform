# ============================================================================
# ClassMate Backend Environment Variables
# ============================================================================
# Copy this file to .env and fill in with your actual values
# NEVER commit .env to version control
# ============================================================================

# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
ENVIRONMENT=development
# Options: development, production
# In production, CORS will be more restrictive and debug mode disabled

# ============================================================================  
# DATABASE CONFIGURATION
# ============================================================================
# Option 1: Use DATABASE_URL (recommended for Railway, Vercel, Heroku)
# For Neon PostgreSQL:
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/database_name?sslmode=require

# Option 2: Use individual variables (for local development)
# Uncomment and configure if not using DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=classmate_db
# DB_USER=postgres
# DB_PASSWORD=your_postgres_password
# DB_SSL=disable

# ============================================================================
# FRONTEND CONFIGURATION (CORS)
# ============================================================================
# Frontend URL for CORS policy
FRONTEND_URL=https://yourdomain.vercel.app
# For Vercel preview deployments:
# VERCEL_DEPLOYMENT_URL=preview-name.yourdomain.vercel.app

# ============================================================================
# PORT CONFIGURATION
# ============================================================================
# Port the Flask app will listen on (Railway/Render sets this automatically)
# Default: 8000
# PORT=8000

# ============================================================================
# LIVEKIT VIDEO CONFIGURATION
# ============================================================================
# Get these from LiveKit Cloud dashboard (https://cloud.livekit.io)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# ============================================================================
# OPTIONAL: FILE UPLOADS
# ============================================================================
# Upload folder (ensure it's writable, or use cloud storage)
UPLOAD_FOLDER=uploads/profile_images
# Maximum upload size in bytes (16MB default)
MAX_CONTENT_LENGTH=16777216

# ============================================================================
# OPTIONAL: JWT/SECURITY
# ============================================================================
# JWT secret key for token signing (generate a strong random key)
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-secret-key-change-this-in-production

# ============================================================================
# OPTIONAL: EMAIL CONFIGURATION (if using password reset emails)
# ============================================================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-specific-password
# MAIL_DEFAULT_SENDER=noreply@classmate.app

# ============================================================================
# OPTIONAL: LOGGING & DEBUGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Enable Flask debug mode (NEVER in production)
# FLASK_DEBUG=False

# ============================================================================
# OPTIONAL: CLOUD STORAGE (for file uploads instead of local filesystem)
# ============================================================================
# If using AWS S3 or similar cloud storage:
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ============================================================================
# RAILWAY SPECIFIC (auto-set, but can override)
# ============================================================================
# RAILWAY_ENVIRONMENT_NAME=production
# RAILWAY_STATIC_URL=
# RAILWAY_PROJECT_ID=
