{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://classmate-backend-eysi.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://classmate-backend-eysi.onrender.com/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}