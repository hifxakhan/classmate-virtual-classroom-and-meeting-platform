# ============================================================================
# ClassMate Frontend Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in with your actual values
# VITE_* variables are exposed to browser (never put secrets here)
# ============================================================================

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================
# Backend API URL (must be accessible from browser)
# In development: http://localhost:5000
# In production: https://your-backend.railway.app
VITE_API_URL=http://localhost:5000

# ============================================================================
# LIVEKIT CONFIGURATION (Optional - if using LiveKit)
# ============================================================================
# LiveKit URL for video calls
VITE_LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# ============================================================================
# SFU SERVER CONFIGURATION
# ============================================================================
# SFU Socket.IO server URL for WebRTC signaling (private calls)
# In development: http://localhost:4001
# In production: https://your-sfu-server.up.railway.app
VITE_SFU_URL=http://localhost:4001

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
# Application name
VITE_APP_NAME=ClassMate

# Application environment
VITE_ENVIRONMENT=development
# Options: development, staging, production

# ============================================================================
# BUILD CONFIGURATION
# ============================================================================
# Vite mode (automatically set based on npm script)
# development / production
NODE_ENV=development
